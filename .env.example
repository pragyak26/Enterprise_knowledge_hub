# Copy to .env and fill in. Never commit your real .env.

# Auth — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Models
EMBEDDING_MODEL=models/gemini-embedding-001
CHAT_MODEL=gemini-2.5-flash

# Storage / DB. Default is local SQLite + on-disk Chroma.
# For Postgres: postgresql+psycopg://user:pass@localhost:5432/ekh
DATABASE_URL=sqlite:///./data/app.db
STORAGE_DIR=./storage
CHROMA_DIR=./data/chroma

# RAG tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
